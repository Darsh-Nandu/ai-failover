# Primary Groq API key (get one free at https://console.groq.com)
GROQ_KEY_1=gsk_your_primary_key_here

# Fallback Groq API key (create a second key from the same account or a new one)
GROQ_KEY_2=gsk_your_fallback_key_here

# Number of concurrent active sessions before switching to Key 2 (default: 10)
THRESHOLD=10

# Port to run the server on (default: 3000)
PORT=3000
